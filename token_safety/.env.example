# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Server
PORT=8001
MODE=api

# Cron protection
CRON_SECRET=your-cron-secret

# Scheduler (set to false if running crons externally)
ENABLE_SCHEDULER=true

# Scheduler intervals (optional, defaults shown)
RADAR_INTERVAL_MIN=30
BATCH_INTERVAL_HOURS=12
LEAGUE_INTERVAL_HOURS=6
LP_MONITOR_INTERVAL_HOURS=2
LP_MONITOR_LIMIT=50
BATCH_LIMIT=200
BLACKLIST_SYNC_INTERVAL_HOURS=24
EXPLOIT_SYNC_INTERVAL_HOURS=168
